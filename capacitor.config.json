{
  "appId": "com.falcon.tv",
  "appName": "Falcon TV",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "raw.githubusercontent.com",
      "tv-api-gateway.trackerwanga254.workers.dev",
      "*.workers.dev",
      "*.githubusercontent.com"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#09090b",
      "showSpinner": true,
      "spinnerColor": "#ef4444"
    }
  }
}
